@page
@model RagChatbot.RazorPages.Pages.Document.CreateModel
@{
    ViewData["Title"] = "Upload Tài liệu";
    var subjectId = Model.SubjectId;
}

<div class="breadcrumb-app">
    <a asp-page="/Subject/Index"><i class="bi bi-book me-1"></i>Môn học</a>
    <span class="sep"><i class="bi bi-chevron-right" style="font-size:10px"></i></span>
    <a asp-page="Index" asp-route-subjectId="@subjectId">Tài liệu</a>
    <span class="sep"><i class="bi bi-chevron-right" style="font-size:10px"></i></span>
    <span class="current">Upload</span>
</div>

<div class="row justify-content-center">
    <div class="col-md-8 col-lg-6">
        <div class="form-card fade-in-up">
            <div style="margin-bottom:24px">
                <h4 style="font-size:18px;font-weight:700;color:var(--text-1);margin:0">Upload Tài liệu</h4>
                <p style="font-size:13px;color:var(--text-2);margin:4px 0 0">
                    AI sẽ tự động đọc và học nội dung tài liệu sau khi upload
                </p>
            </div>

            @if (!ViewData.ModelState.IsValid)
            {
                <div class="alert-app" style="background:rgba(239,68,68,.12);border:1px solid rgba(239,68,68,.3);border-radius:10px;padding:12px 16px;margin-bottom:20px;display:flex;gap:10px;align-items:flex-start">
                    <i class="bi bi-exclamation-triangle-fill" style="color:#f87171;flex-shrink:0;margin-top:2px"></i>
                    <div style="font-size:13px;color:#fca5a5;line-height:1.5">
                        @Html.ValidationSummary(excludePropertyErrors: false, message: "", htmlAttributes: new { @style = "margin:0;padding:0;list-style:none" })
                    </div>
                </div>
            }

            <form method="post" enctype="multipart/form-data" id="uploadForm">
                <input type="hidden" name="subjectId" value="@subjectId" />

                <label class="upload-zone" for="fileInput" id="uploadZone">
                    <i class="bi bi-cloud-arrow-up upload-icon" id="uploadIcon"></i>
                    <div style="font-size:15px;font-weight:600;color:var(--text-1);margin-bottom:6px" id="uploadText">
                        Kéo thả file vào đây hoặc nhấn để chọn
                    </div>
                    <div style="font-size:12px;color:var(--text-3)">Hỗ trợ: PDF, TXT, DOCX</div>
                    <input type="file" id="fileInput" name="UploadFile" style="display:none" required
                           accept=".pdf,.txt,.docx,.doc" />
                </label>

                <div style="margin-top:16px;">
                    <label style="font-size:13px;font-weight:600;color:var(--text-2);margin-bottom:6px;display:block">Quyền riêng tư</label>
                    <select name="AccessLevel" class="form-control" style="width:100%;padding:10px;border-radius:8px;border:1px solid var(--border-color);background:var(--bg-2);color:var(--text-1)">
                        <option value="0">Công khai (Sinh viên có thể xem và AI sẽ học)</option>
                        <option value="1">Riêng tư (Chỉ mình tôi thấy)</option>
                        <option value="2">Nội bộ Giảng viên (Chỉ Giảng viên/Admin mới thấy)</option>
                    </select>
                </div>

                <div style="margin-top:24px;display:flex;gap:10px">
                    <button type="submit" class="btn-app btn-primary-app" id="submitBtn">
                        <i class="bi bi-upload"></i> Upload & Xử lý AI
                    </button>
                    <a asp-page="Index" asp-route-subjectId="@subjectId" class="btn-app btn-ghost">
                        <i class="bi bi-arrow-left"></i> Quay lại
                    </a>
                </div>
            </form>
        </div>

        <div class="alert-app alert-info-app" style="margin-top:16px">
            <i class="bi bi-info-circle-fill" style="flex-shrink:0"></i>
            <div>
                <strong>Lưu ý:</strong> Sau khi upload, AI sẽ tự động đọc và lập chỉ mục tài liệu.
                Quá trình này có thể mất vài giây đến vài phút tùy kích thước file.
            </div>
        </div>
    </div>
</div>

@section Scripts {
<script>
    const fileInput = document.getElementById('fileInput');
    const uploadText = document.getElementById('uploadText');
    const uploadIcon = document.getElementById('uploadIcon');
    const uploadZone = document.getElementById('uploadZone');
    const submitBtn = document.getElementById('submitBtn');

    fileInput.addEventListener('change', function() {
        if (this.files.length > 0) {
            const name = this.files[0].name;
            uploadText.textContent = '✅ ' + name;
            uploadIcon.className = 'bi bi-file-earmark-check upload-icon';
            uploadZone.style.borderColor = 'var(--success)';
            uploadZone.style.background = '#F0FDF4';
        }
    });

    document.getElementById('uploadForm').addEventListener('submit', function() {
        submitBtn.disabled = true;
        submitBtn.innerHTML = '<i class="bi bi-hourglass-split"></i> Đang xử lý...';
    });

    const zone = uploadZone;
    zone.addEventListener('dragover', e => { e.preventDefault(); zone.classList.add('drag-over'); });
    zone.addEventListener('dragleave', () => zone.classList.remove('drag-over'));
    zone.addEventListener('drop', e => {
        e.preventDefault();
        zone.classList.remove('drag-over');
        if (e.dataTransfer.files.length) {
            fileInput.files = e.dataTransfer.files;
            fileInput.dispatchEvent(new Event('change'));
        }
    });
</script>
}
