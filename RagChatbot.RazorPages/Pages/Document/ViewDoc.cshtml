@page
@model RagChatbot.RazorPages.Pages.Document.ViewDocModel
@{
    var doc      = Model.Document;
    ViewData["Title"] = doc.FileName;
    var ext      = System.IO.Path.GetExtension(doc.FileName).ToLower();
    var chunks   = Model.Chunks;
    var total    = chunks.Count;
    var words    = Model.TotalWords;
    var avgWords = total > 0 ? words / total : 0;
}

<div class="breadcrumb-app">
    <a asp-page="/Subject/Index"><i class="bi bi-book me-1"></i>Môn học</a>
    <span class="sep"><i class="bi bi-chevron-right" style="font-size:10px"></i></span>
    <a asp-page="Index" asp-route-subjectId="@doc.SubjectId">Tài liệu</a>
    <span class="sep"><i class="bi bi-chevron-right" style="font-size:10px"></i></span>
    <span class="current">@doc.FileName</span>
</div>

<!-- File header -->
<div style="display:flex;align-items:center;justify-content:space-between;margin-bottom:16px;gap:12px;flex-wrap:wrap" class="fade-in-up">
    <div style="display:flex;align-items:center;gap:10px">
        <div class="file-icon @(ext == ".pdf" ? "pdf" : ext == ".txt" ? "txt" : ext == ".docx" ? "docx" : "other")" style="width:40px;height:40px;font-size:20px">
            <i class="bi @(ext == ".pdf" ? "bi-file-earmark-pdf" : ext == ".txt" ? "bi-file-earmark-text" : "bi-file-earmark")"></i>
        </div>
        <div>
            <div style="font-size:16px;font-weight:700;color:var(--text-1)">@doc.FileName</div>
            <div style="font-size:12px;color:var(--text-3)">Tải lên lúc @doc.UploadedAt.ToLocalTime().ToString("dd/MM/yyyy HH:mm")</div>
        </div>
    </div>
    <div style="display:flex;gap:8px">
        <a asp-page="/Quiz/Generate" asp-route-documentId="@doc.Id" class="btn-app btn-sm-app" style="background:#8b5cf6;color:#fff;border-color:#8b5cf6">
            <i class="bi bi-magic"></i> Tạo Quiz AI
        </a>
        <a asp-page="Index" asp-route-subjectId="@doc.SubjectId" class="btn-app btn-ghost btn-sm-app">
            <i class="bi bi-arrow-left"></i> Danh sách
        </a>
        <a asp-page="Download" asp-route-id="@doc.Id" class="btn-app btn-primary-app btn-sm-app">
            <i class="bi bi-download"></i> Tải về
        </a>
    </div>
</div>

<!-- Tab bar -->
<div class="vd-tabs fade-in-up">
    <button class="vd-tab active" onclick="switchTab('viewer', this)">
        <i class="bi bi-eye"></i> Xem tài liệu
    </button>
    <button class="vd-tab" onclick="switchTab('chunks', this)">
        <i class="bi bi-grid-3x3-gap"></i>
        Phân tích Chunk
        <span class="chunk-count-badge">@total</span>
    </button>
</div>

<!-- ===== TAB: Viewer ===== -->
<div id="tab-viewer" class="vd-pane fade-in-up">
    <div class="card" style="overflow:hidden;height:calc(100vh - var(--topbar-height) - 210px)">
        @if (ext == ".pdf")
        {
            <iframe src="@doc.FilePath" style="width:100%;height:100%;border:none;display:block"></iframe>
        }
        else if (ext == ".txt")
        {
            <div style="height:100%;overflow-y:auto;background:#1E1E2E;padding:24px">
                <pre style="margin:0;white-space:pre-wrap;font-family:'Consolas','Courier New',monospace;font-size:14px;line-height:1.7;color:#CDD6F4">@Model.FileContent</pre>
            </div>
        }
        else if (ext == ".jpg" || ext == ".png" || ext == ".jpeg" || ext == ".gif")
        {
            <div style="height:100%;display:flex;align-items:center;justify-content:center;background:#0F172A">
                <img src="@doc.FilePath" style="max-width:100%;max-height:100%;object-fit:contain" alt="@doc.FileName" />
            </div>
        }
        else
        {
            <div style="height:100%;display:flex;flex-direction:column;align-items:center;justify-content:center;gap:16px;padding:40px;text-align:center">
                <i class="bi bi-file-earmark-x" style="font-size:64px;color:var(--text-3)"></i>
                <div>
                    <div style="font-size:16px;font-weight:600;color:var(--text-2)">Trình duyệt không hỗ trợ xem định dạng này</div>
                    <div style="font-size:13px;color:var(--text-3);margin-top:6px">Vui lòng tải file về để xem nội dung</div>
                </div>
                <a asp-page="Download" asp-route-id="@doc.Id" class="btn-app btn-success-app">
                    <i class="bi bi-download"></i> Tải file về máy
                </a>
            </div>
        }
    </div>
</div>

<!-- ===== TAB: Chunks ===== -->
<div id="tab-chunks" class="vd-pane d-none">

    @if (total == 0)
    {
        <div class="table-card fade-in-up">
            <div class="empty-state">
                <span class="empty-icon"><i class="bi bi-grid-3x3-gap"></i></span>
                <div class="empty-title">Chưa có chunk nào</div>
                <div class="empty-sub">
                    Tài liệu này chưa được AI xử lý hoặc xử lý thất bại.<br/>
                    Trạng thái hiện tại: <strong>@doc.Status</strong>
                </div>
            </div>
        </div>
    }
    else
    {
        <!-- Stat cards -->
        <div class="chunk-stats-row fade-in-up">
            <div class="chunk-stat-card">
                <div class="csc-icon"><i class="bi bi-grid-3x3-gap-fill"></i></div>
                <div>
                    <div class="csc-value">@total</div>
                    <div class="csc-label">Tổng số chunk</div>
                </div>
            </div>
            <div class="chunk-stat-card">
                <div class="csc-icon" style="background:rgba(16,185,129,.12);color:#10b981"><i class="bi bi-file-word"></i></div>
                <div>
                    <div class="csc-value">@words.ToString("N0")</div>
                    <div class="csc-label">Tổng số từ</div>
                </div>
            </div>
            <div class="chunk-stat-card">
                <div class="csc-icon" style="background:rgba(245,158,11,.12);color:#f59e0b"><i class="bi bi-calculator"></i></div>
                <div>
                    <div class="csc-value">~@avgWords</div>
                    <div class="csc-label">Từ trung bình / chunk</div>
                </div>
            </div>
            <div class="chunk-stat-card">
                <div class="csc-icon" style="background:rgba(139,92,246,.12);color:#8b5cf6"><i class="bi bi-cpu"></i></div>
                <div>
                    <div class="csc-value">768</div>
                    <div class="csc-label">Chiều vector embedding</div>
                </div>
            </div>
        </div>



        <!-- Chunk cards -->
        <div class="chunk-list fade-in-up">
            @foreach (var chunk in chunks)
            {
                <div class="chunk-card" id="chunk-@chunk.Index">
                    <div class="chunk-card-header" onclick="toggleChunk(@chunk.Index)">
                        <div style="display:flex;align-items:center;gap:12px">
                            <span class="chunk-index-badge">#@chunk.Index</span>
                            <div>
                                <div style="font-size:13px;font-weight:600;color:var(--text-1)">Chunk @chunk.Index / @total</div>
                                <div style="font-size:12px;color:var(--text-3)">@chunk.WordCount từ &nbsp;·&nbsp; ~@(chunk.WordCount * 5) ký tự</div>
                            </div>
                        </div>
                        <div style="display:flex;align-items:center;gap:8px">
                            <span class="chunk-word-badge">@chunk.WordCount từ</span>
                            <i class="bi bi-chevron-down chunk-chevron" id="chev-@chunk.Index"></i>
                        </div>
                    </div>
                    <div class="chunk-card-body d-none" id="body-@chunk.Index">
                        <div class="chunk-preview">@(chunk.TextContent?.Length > 300 ? chunk.TextContent.Substring(0, 300) + "…" : chunk.TextContent)</div>
                        @if (chunk.TextContent?.Length > 300)
                        {
                            <button class="btn-show-more" onclick="showFull(@chunk.Index, this)">
                                <i class="bi bi-chevron-double-down"></i> Xem toàn bộ
                            </button>
                            <div class="chunk-full d-none" id="full-@chunk.Index">@chunk.TextContent</div>
                        }
                        <div class="chunk-vector-hint">
                            <i class="bi bi-cpu"></i>
                            Chunk này đã được mã hoá thành vector 768 chiều và lưu vào pgvector
                        </div>
                    </div>
                </div>
            }
        </div>
    }
</div>

@section Scripts {
<style>
/* ---- Tab bar ---- */
.vd-tabs {
    display: flex;
    gap: 4px;
    background: var(--surface-2);
    border-radius: 12px;
    padding: 4px;
    margin-bottom: 16px;
    width: fit-content;
}
.vd-tab {
    display: flex;
    align-items: center;
    gap: 6px;
    padding: 8px 18px;
    border-radius: 9px;
    border: none;
    background: transparent;
    color: var(--text-2);
    font-size: 13px;
    font-weight: 500;
    cursor: pointer;
    transition: all .2s;
}
.vd-tab:hover { color: var(--text-1); background: var(--surface-3); }
.vd-tab.active { background: var(--primary); color: #fff; box-shadow: 0 2px 8px rgba(99,102,241,.35); }
.chunk-count-badge {
    background: rgba(255,255,255,.25);
    color: inherit;
    font-size: 11px;
    font-weight: 700;
    padding: 1px 7px;
    border-radius: 20px;
    margin-left: 2px;
}
.vd-tab:not(.active) .chunk-count-badge { background: var(--primary); color: #fff; }

/* ---- Stat row ---- */
.chunk-stats-row {
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(170px, 1fr));
    gap: 12px;
    margin-bottom: 16px;
}
.chunk-stat-card {
    background: var(--surface-2);
    border: 1px solid var(--border);
    border-radius: 12px;
    padding: 16px;
    display: flex;
    align-items: center;
    gap: 12px;
}
.csc-icon {
    width: 40px; height: 40px;
    border-radius: 10px;
    background: rgba(99,102,241,.12);
    color: var(--primary);
    display: flex; align-items: center; justify-content: center;
    font-size: 18px; flex-shrink: 0;
}
.csc-value { font-size: 22px; font-weight: 800; color: var(--text-1); line-height: 1.1; }
.csc-label { font-size: 11px; color: var(--text-3); margin-top: 2px; }

/* ---- Pipeline ---- */
.chunk-pipeline {
    display: flex;
    align-items: center;
    gap: 8px;
    background: var(--surface-2);
    border: 1px solid var(--border);
    border-radius: 12px;
    padding: 14px 20px;
    margin-bottom: 16px;
    flex-wrap: wrap;
}
.pipeline-step {
    display: flex; align-items: center; gap: 6px;
    font-size: 12px; font-weight: 500; color: var(--text-2);
    padding: 6px 12px;
    border-radius: 8px;
    background: var(--surface-3);
}
.pipeline-step.active {
    background: rgba(99,102,241,.15);
    color: var(--primary);
    font-weight: 700;
    box-shadow: 0 0 0 1px rgba(99,102,241,.3);
}
.pipeline-arrow { color: var(--text-3); font-size: 14px; }

/* ---- Semantic info banner ---- */
.semantic-info {
    display: flex; align-items: flex-start; gap: 8px;
    font-size: 12px; color: var(--text-2);
    background: rgba(99,102,241,.07);
    border: 1px solid rgba(99,102,241,.2);
    border-left: 3px solid var(--primary);
    border-radius: 8px;
    padding: 10px 14px;
    margin-bottom: 16px;
    line-height: 1.6;
}
.semantic-info i { color: var(--primary); font-size: 14px; flex-shrink: 0; margin-top: 1px; }

/* ---- Chunk list ---- */
.chunk-list { display: flex; flex-direction: column; gap: 8px; }
.chunk-card {
    background: var(--surface-2);
    border: 1px solid var(--border);
    border-radius: 12px;
    overflow: hidden;
    transition: box-shadow .2s;
}
.chunk-card:hover { box-shadow: 0 4px 16px rgba(0,0,0,.12); }
.chunk-card-header {
    display: flex; align-items: center; justify-content: space-between;
    padding: 14px 16px;
    cursor: pointer;
    user-select: none;
}
.chunk-card-header:hover { background: var(--surface-3); }
.chunk-index-badge {
    width: 36px; height: 36px;
    border-radius: 8px;
    background: linear-gradient(135deg, var(--primary), var(--secondary));
    color: #fff;
    display: flex; align-items: center; justify-content: center;
    font-size: 11px; font-weight: 800;
    flex-shrink: 0;
}
.chunk-word-badge {
    font-size: 11px; font-weight: 600;
    padding: 3px 10px;
    border-radius: 20px;
    background: rgba(99,102,241,.1);
    color: var(--primary);
}
.chunk-chevron { color: var(--text-3); transition: transform .25s; }
.chunk-chevron.open { transform: rotate(180deg); }

.chunk-card-body { padding: 0 16px 16px; }
.chunk-preview {
    font-size: 13px;
    line-height: 1.75;
    color: var(--text-2);
    background: var(--surface-3);
    border-radius: 8px;
    padding: 12px 14px;
    white-space: pre-wrap;
    word-break: break-word;
}
.chunk-full {
    font-size: 13px; line-height: 1.75; color: var(--text-2);
    background: var(--surface-3);
    border-radius: 8px; padding: 12px 14px;
    white-space: pre-wrap; word-break: break-word;
    margin-top: 8px;
}
.btn-show-more {
    display: flex; align-items: center; gap: 6px;
    margin-top: 8px;
    font-size: 12px; font-weight: 600;
    color: var(--primary);
    background: none; border: none; cursor: pointer; padding: 0;
}
.btn-show-more:hover { text-decoration: underline; }
.chunk-vector-hint {
    margin-top: 10px;
    font-size: 11px;
    color: var(--text-3);
    display: flex; align-items: center; gap: 6px;
    padding: 6px 10px;
    background: rgba(139,92,246,.08);
    border-radius: 6px;
    border-left: 3px solid #8b5cf6;
}
</style>

<script>
function switchTab(name, btn) {
    document.querySelectorAll('.vd-pane').forEach(p => p.classList.add('d-none'));
    document.querySelectorAll('.vd-tab').forEach(b => b.classList.remove('active'));
    document.getElementById('tab-' + name).classList.remove('d-none');
    btn.classList.add('active');
}

function toggleChunk(index) {
    var body = document.getElementById('body-' + index);
    var chev = document.getElementById('chev-' + index);
    body.classList.toggle('d-none');
    chev.classList.toggle('open');
}

function showFull(index, btn) {
    var preview = btn.previousElementSibling;
    var full    = document.getElementById('full-' + index);
    preview.classList.add('d-none');
    btn.classList.add('d-none');
    full.classList.remove('d-none');
}
</script>
}
