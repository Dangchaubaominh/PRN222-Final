@page
@model RagChatbot.RazorPages.Pages.Benchmark.IndexModel
@{
    ViewData["Title"] = "Benchmark Models";
}

<div class="breadcrumb-app fade-in-up">
    <a asp-page="/Index"><i class="bi bi-house-door me-1"></i>Trang chủ</a>
    <span class="sep"><i class="bi bi-chevron-right" style="font-size:10px"></i></span>
    <span class="current">Benchmark Models</span>
</div>

<div class="row fade-in-up">
    <!-- Form tạo Benchmark -->
    <div class="col-lg-4 mb-4">
        <div class="form-card">
            <h5 style="font-weight:700;margin-bottom:20px;color:var(--text-1)"><i class="bi bi-play-circle-fill" style="color:var(--primary);margin-right:8px"></i> Chạy Benchmark Mới</h5>
            
            <form method="post">
                @if (!ViewData.ModelState.IsValid)
                {
                    <div class="alert alert-danger" style="font-size:13px;padding:10px;border-radius:8px">
                        <div asp-validation-summary="All" style="margin-bottom:0"></div>
                    </div>
                }

                <div class="form-group mb-3">
                    <label class="form-label" style="font-size:13px;font-weight:600;color:var(--text-2)">Môn học tham chiếu</label>
                    <select asp-for="Input.SubjectId" asp-items="Model.SubjectList" class="form-select form-control" style="background:var(--bg-2);color:var(--text-1);border-color:var(--border-color)">
                        <option value="">-- Chọn môn học --</option>
                    </select>
                </div>

                <div class="form-group mb-3">
                    <label class="form-label" style="font-size:13px;font-weight:600;color:var(--text-2)">Các Model cần test</label>
                    <div style="background:var(--bg-2);padding:10px;border-radius:8px;border:1px solid var(--border-color)">
                        @foreach (var m in Model.ModelOptions)
                        {
                            <div class="form-check">
                                <input class="form-check-input" type="checkbox" name="Input.SelectedModels" value="@m.Value" id="chk_@m.Value" checked>
                                <label class="form-check-label" for="chk_@m.Value" style="font-size:13px;color:var(--text-2)">
                                    @m.Text
                                </label>
                            </div>
                        }
                    </div>
                </div>

                <div class="form-group mb-4">
                    <label class="form-label" style="font-size:13px;font-weight:600;color:var(--text-2)">Câu hỏi (Mỗi câu 1 dòng)</label>
                    <textarea asp-for="Input.QuestionsText" class="form-control" rows="5" style="background:var(--bg-2);color:var(--text-1);border-color:var(--border-color)" placeholder="VD: Khái niệm OOP là gì?&#10;Liệt kê các tính chất của OOP."></textarea>
                </div>

                <button type="submit" class="btn-app btn-primary-app w-100" id="btnRun">
                    <i class="bi bi-lightning-charge"></i> Bắt đầu chạy
                </button>
            </form>
        </div>
    </div>

    <!-- Lịch sử và kết quả -->
    <div class="col-lg-8">
        @if (!Model.Runs.Any())
        {
            <div class="table-card">
                <div class="empty-state">
                    <span class="empty-icon"><i class="bi bi-bar-chart"></i></span>
                    <div class="empty-title">Chưa có kết quả benchmark nào</div>
                    <div class="empty-sub">Hãy chạy benchmark mới ở biểu mẫu bên trái.</div>
                </div>
            </div>
        }
        else
        {
            @foreach (var run in Model.Runs)
            {
                var idChart = "chart_" + run.Id;
                <div class="table-card mb-4">
                    <div style="display:flex;justify-content:space-between;align-items:center;margin-bottom:16px;flex-wrap:wrap;gap:10px">
                        <div>
                            <h6 style="margin:0;font-weight:700;color:var(--text-1)">Run #@run.Id</h6>
                            <div style="font-size:12px;color:var(--text-3)">@run.CreatedAt.ToLocalTime().ToString("dd/MM/yyyy HH:mm") - Môn: @run.Subject?.Name</div>
                        </div>
                        <span class="badge" style="background:rgba(99,102,241,.15);color:var(--primary);padding:6px 12px;font-size:12px">@run.Results.Count kết quả</span>
                    </div>

                    <div style="height:300px;margin-bottom:24px">
                        <canvas id="@idChart"></canvas>
                    </div>

                    <div class="table-responsive">
                        <table class="table-app">
                            <thead>
                                <tr>
                                    <th>Model</th>
                                    <th>Câu hỏi</th>
                                    <th>Latency</th>
                                    <th>Tokens</th>
                                    <th>Cost Est.</th>
                                </tr>
                            </thead>
                            <tbody>
                                @foreach (var r in run.Results)
                                {
                                    <tr>
                                        <td><span style="font-weight:600;font-size:12px;padding:3px 8px;border-radius:4px;background:rgba(255,255,255,.05)">@r.Model</span></td>
                                        <td style="max-width:200px;white-space:nowrap;overflow:hidden;text-overflow:ellipsis" title="@r.Question">@r.Question</td>
                                        <td>@r.LatencyMs ms</td>
                                        <td>@r.TotalTokens</td>
                                        <td style="color:#10b981">$@r.EstimatedCost.ToString("N6")</td>
                                    </tr>
                                }
                            </tbody>
                        </table>
                    </div>
                </div>
            }
        }
    </div>
</div>

@section Scripts {
    <script src="https://cdn.jsdelivr.net/npm/chart.js"></script>
    <script>
        document.querySelector('form').addEventListener('submit', function() {
            var btn = document.getElementById('btnRun');
            btn.disabled = true;
            btn.innerHTML = '<i class="bi bi-hourglass-split"></i> Đang chạy...';
        });

        const runs = @Html.Raw(System.Text.Json.JsonSerializer.Serialize(
            Model.Runs.Select(r => new {
                id = r.Id,
                results = r.Results.Select(res => new { model = res.Model, latency = res.LatencyMs })
            })
        ));

        runs.forEach(run => {
            const ctx = document.getElementById('chart_' + run.id);
            if (!ctx) return;

            // Tính trung bình latency theo model
            const modelMap = {};
            run.results.forEach(res => {
                if (!modelMap[res.model]) modelMap[res.model] = [];
                modelMap[res.model].push(res.latency);
            });

            const labels = Object.keys(modelMap);
            const data = labels.map(l => {
                const arr = modelMap[l];
                return arr.reduce((a, b) => a + b, 0) / arr.length;
            });

            new Chart(ctx, {
                type: 'bar',
                data: {
                    labels: labels,
                    datasets: [{
                        label: 'Trung bình Latency (ms)',
                        data: data,
                        backgroundColor: 'rgba(99, 102, 241, 0.6)',
                        borderColor: 'rgba(99, 102, 241, 1)',
                        borderWidth: 1,
                        borderRadius: 4
                    }]
                },
                options: {
                    responsive: true,
                    maintainAspectRatio: false,
                    plugins: {
                        legend: { labels: { color: '#94a3b8' } }
                    },
                    scales: {
                        y: {
                            beginAtZero: true,
                            grid: { color: 'rgba(255,255,255,0.05)' },
                            ticks: { color: '#94a3b8' }
                        },
                        x: {
                            grid: { display: false },
                            ticks: { color: '#94a3b8' }
                        }
                    }
                }
            });
        });
    </script>
}
