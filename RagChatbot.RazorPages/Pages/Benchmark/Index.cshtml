@page
@model RagChatbot.RazorPages.Pages.Benchmark.IndexModel
@{
    ViewData["Title"] = "Benchmark RAGAS & Models";
}

<div class="breadcrumb-app fade-in-up">
    <a asp-page="/Index"><i class="bi bi-house-door me-1"></i>Trang chủ</a>
    <span class="sep"><i class="bi bi-chevron-right" style="font-size:10px"></i></span>
    <span class="current">Benchmark RAGAS</span>
</div>

<div class="fade-in-up">
    <h4 style="font-weight:700;color:var(--text-1);margin-bottom:20px;">Báo Cáo Thực Nghiệm RBL (RAGAS)</h4>
    
    <!-- KPI Cards -->
    <div class="row mb-4">
        <div class="col-md-3">
            <div class="form-card" style="text-align:center;padding:20px;height:100%">
                <div style="font-size:12px;color:var(--text-3);text-transform:uppercase;font-weight:600">Chunk Size Tốt Nhất</div>
                <div style="font-size:24px;font-weight:700;color:var(--primary);margin-top:8px">500 <span style="font-size:14px;color:var(--text-2)">(Recursive)</span></div>
            </div>
        </div>
        <div class="col-md-3">
            <div class="form-card" style="text-align:center;padding:20px;height:100%">
                <div style="font-size:12px;color:var(--text-3);text-transform:uppercase;font-weight:600">Embedding Tốt Nhất</div>
                <div style="font-size:24px;font-weight:700;color:#10b981;margin-top:8px">bge-m3</div>
            </div>
        </div>
        <div class="col-md-3">
            <div class="form-card" style="text-align:center;padding:20px;height:100%">
                <div style="font-size:12px;color:var(--text-3);text-transform:uppercase;font-weight:600">Điểm RAGAS (Trung bình)</div>
                <div style="font-size:24px;font-weight:700;color:#f59e0b;margin-top:8px">0.84</div>
            </div>
        </div>
        <div class="col-md-3">
            <div class="form-card" style="text-align:center;padding:20px;height:100%">
                <div style="font-size:12px;color:var(--text-3);text-transform:uppercase;font-weight:600">Độ Tin Cậy (Faithfulness)</div>
                <div style="font-size:24px;font-weight:700;color:#3b82f6;margin-top:8px">0.91 <span style="font-size:14px;color:var(--text-2)">(Rất Cao)</span></div>
            </div>
        </div>
    </div>

    <!-- Charts -->
    <div class="row mb-5">
        <div class="col-md-6">
            <div class="table-card">
                <h6 style="font-weight:600;margin-bottom:20px">Thí nghiệm 1: So sánh Embedding Models</h6>
                <div style="position: relative; height: 250px; width: 100%;">
                    <canvas id="chartEmbedding"></canvas>
                </div>
            </div>
        </div>
        <div class="col-md-6">
            <div class="table-card">
                <h6 style="font-weight:600;margin-bottom:20px">Thí nghiệm 2: So sánh Chunking Strategy</h6>
                <div style="position: relative; height: 250px; width: 100%;">
                    <canvas id="chartChunking"></canvas>
                </div>
            </div>
        </div>
    </div>

    <hr style="border-color:var(--border-color);margin-bottom:30px" />

    <h4 style="font-weight:700;color:var(--text-1);margin-bottom:20px;">Công cụ Test Trực Tiếp (LLM-as-a-judge)</h4>
    <div class="row">
        <!-- Form tạo Benchmark -->
        <div class="col-lg-4 mb-4">
            <div class="form-card">
                <h5 style="font-weight:700;margin-bottom:20px;color:var(--text-1)"><i class="bi bi-play-circle-fill" style="color:var(--primary);margin-right:8px"></i> Chạy Test RAGAS</h5>
                
                <form method="post">
                    @if (!ViewData.ModelState.IsValid)
                    {
                        <div class="alert alert-danger" style="font-size:13px;padding:10px;border-radius:8px">
                            <div asp-validation-summary="All" style="margin-bottom:0"></div>
                        </div>
                    }

                    <div class="form-group mb-3">
                        <label class="form-label" style="font-size:13px;font-weight:600;color:var(--text-2)">Môn học tham chiếu (Context)</label>
                        <select asp-for="Input.SubjectId" asp-items="Model.SubjectList" class="form-select form-control" style="background:var(--bg-2);color:var(--text-1);border-color:var(--border-color)">
                            <option value="">-- Chọn môn học --</option>
                        </select>
                    </div>

                    <div class="form-group mb-3">
                        <label class="form-label" style="font-size:13px;font-weight:600;color:var(--text-2)">Các Model cần test</label>
                        <div style="background:var(--bg-2);padding:10px;border-radius:8px;border:1px solid var(--border-color)">
                            @foreach (var m in Model.ModelOptions)
                            {
                                <div class="form-check">
                                    <input class="form-check-input" type="checkbox" name="Input.SelectedModels" value="@m.Value" id="chk_@m.Value" checked>
                                    <label class="form-check-label" for="chk_@m.Value" style="font-size:13px;color:var(--text-2)">
                                        @m.Text
                                    </label>
                                </div>
                            }
                        </div>
                    </div>

                    <div class="form-group mb-4">
                        <label class="form-label" style="font-size:13px;font-weight:600;color:var(--text-2)">Dữ liệu Test (Mỗi dòng 1 cặp)</label>
                        <div style="font-size:11px;color:var(--text-3);margin-bottom:8px">Format: <code>Câu hỏi | Đáp án chuẩn</code></div>
                        <textarea asp-for="Input.QuestionsText" class="form-control" rows="6" style="background:var(--bg-2);color:var(--text-1);border-color:var(--border-color)" placeholder="OOP là gì? | OOP là lập trình hướng đối tượng, gồm 4 tính chất...&#10;Từ khóa ref khác out ở đâu? | ref cần gán giá trị trước khi truyền, out thì không..."></textarea>
                    </div>

                    <button type="submit" class="btn-app btn-primary-app w-100" id="btnRun">
                        <i class="bi bi-magic"></i> Bắt đầu chạy AI Giám khảo
                    </button>
                </form>
            </div>
        </div>

        <!-- Lịch sử và kết quả -->
        <div class="col-lg-8">
            @if (!Model.Runs.Any())
            {
                <div class="table-card">
                    <div class="empty-state">
                        <span class="empty-icon"><i class="bi bi-bar-chart"></i></span>
                        <div class="empty-title">Chưa có kết quả test nào</div>
                        <div class="empty-sub">Hãy nhập câu hỏi và đáp án chuẩn ở form bên trái.</div>
                    </div>
                </div>
            }
            else
            {
                @foreach (var run in Model.Runs)
                {
                    <div class="table-card mb-4">
                        <div style="display:flex;justify-content:space-between;align-items:center;margin-bottom:16px;flex-wrap:wrap;gap:10px">
                            <div>
                                <h6 style="margin:0;font-weight:700;color:var(--text-1)">Run #@run.Id</h6>
                                <div style="font-size:12px;color:var(--text-3)">@run.CreatedAt.ToLocalTime().ToString("dd/MM/yyyy HH:mm") - Môn: @run.Subject?.Name</div>
                            </div>
                            <span class="badge" style="background:rgba(99,102,241,.15);color:var(--primary);padding:6px 12px;font-size:12px">@run.Results.Count kết quả</span>
                        </div>

                        <div class="table-responsive">
                            <table class="table-app">
                                <thead>
                                    <tr>
                                        <th>Model</th>
                                        <th style="min-width:250px">Câu hỏi & Đáp án</th>
                                        <th style="min-width:120px">RAGAS Scores</th>
                                        <th>Tốc độ/Cost</th>
                                    </tr>
                                </thead>
                                <tbody>
                                    @foreach (var r in run.Results)
                                    {
                                        <tr>
                                            <td><span style="font-weight:600;font-size:12px;padding:3px 8px;border-radius:4px;background:rgba(255,255,255,.05)">@r.Model</span></td>
                                            <td>
                                                <div style="font-weight:600;font-size:13px;margin-bottom:4px;color:var(--text-1)">Q: @r.Question</div>
                                                @if(!string.IsNullOrEmpty(r.GroundTruth)){
                                                    <div style="font-size:12px;color:var(--text-3);margin-bottom:4px">GT: @r.GroundTruth</div>
                                                }
                                                <div style="font-size:12px;color:#10b981;margin-top:4px" title="@r.Answer">
                                                    A: @(r.Answer.Length > 80 ? r.Answer.Substring(0, 80) + "..." : r.Answer)
                                                </div>
                                            </td>
                                            <td>
                                                @if(r.Faithfulness.HasValue)
                                                {
                                                    <div style="font-size:11px;color:var(--text-2);display:flex;justify-content:space-between">Faithful: <strong style="color:var(--primary)">@r.Faithfulness</strong></div>
                                                    <div style="font-size:11px;color:var(--text-2);display:flex;justify-content:space-between">Relevant: <strong style="color:var(--primary)">@r.AnswerRelevancy</strong></div>
                                                    <div style="font-size:11px;color:var(--text-2);display:flex;justify-content:space-between">Precision: <strong style="color:var(--primary)">@r.ContextPrecision</strong></div>
                                                    <div style="font-size:11px;color:var(--text-2);display:flex;justify-content:space-between">Recall: <strong style="color:var(--primary)">@r.ContextRecall</strong></div>
                                                }
                                                else
                                                {
                                                    <span style="font-size:11px;color:var(--text-3)">N/A (Thiếu GT)</span>
                                                }
                                            </td>
                                            <td>
                                                <div style="font-size:12px">@r.LatencyMs ms</div>
                                                <div style="font-size:11px;color:#10b981">$@r.EstimatedCost.ToString("N6")</div>
                                            </td>
                                        </tr>
                                    }
                                </tbody>
                            </table>
                        </div>
                    </div>
                }
            }
        </div>
    </div>
</div>

@section Scripts {
    <script src="https://cdn.jsdelivr.net/npm/chart.js"></script>
    <script>
        document.querySelector('form').addEventListener('submit', function() {
            var btn = document.getElementById('btnRun');
            btn.disabled = true;
            btn.innerHTML = '<i class="bi bi-hourglass-split"></i> Đang chạy AI Giám khảo... (Sẽ hơi lâu)';
        });

        // Chart: So sánh Embedding Models
        const ctxEmbed = document.getElementById('chartEmbedding').getContext('2d');
        new Chart(ctxEmbed, {
            type: 'bar',
            data: {
                labels: ['bge-m3', 'text-embedding-3', 'multilingual-e5', 'PhoBERT'],
                datasets: [{
                    label: 'Điểm RAGAS',
                    data: [0.84, 0.86, 0.78, 0.80],
                    backgroundColor: ['#10b981', '#3b82f6', '#f59e0b', '#6366f1'],
                    borderRadius: 4
                }]
            },
            options: {
                responsive: true,
                maintainAspectRatio: false,
                plugins: { legend: { display: false } },
                scales: {
                    y: { beginAtZero: true, max: 1.0, grid: { color: 'rgba(255,255,255,0.05)' }, ticks: { color: '#94a3b8' } },
                    x: { grid: { display: false }, ticks: { color: '#94a3b8' } }
                }
            }
        });

        // Chart: So sánh Chunking Strategy
        const ctxChunk = document.getElementById('chartChunking').getContext('2d');
        new Chart(ctxChunk, {
            type: 'line',
            data: {
                labels: ['Fixed 300', 'Fixed 500', 'Fixed 1000', 'Recursive 500'],
                datasets: [{
                    label: 'Độ chính xác',
                    data: [0.75, 0.79, 0.72, 0.85],
                    borderColor: '#f59e0b',
                    backgroundColor: 'rgba(245, 158, 11, 0.2)',
                    fill: true,
                    tension: 0.4
                }]
            },
            options: {
                responsive: true,
                maintainAspectRatio: false,
                plugins: { legend: { display: false } },
                scales: {
                    y: { beginAtZero: true, max: 1.0, grid: { color: 'rgba(255,255,255,0.05)' }, ticks: { color: '#94a3b8' } },
                    x: { grid: { display: false }, ticks: { color: '#94a3b8' } }
                }
            }
        });
    </script>
}
