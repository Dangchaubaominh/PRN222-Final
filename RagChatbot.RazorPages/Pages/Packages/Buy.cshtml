@page
@model RagChatbot.RazorPages.Pages.Packages.BuyModel
@{
    ViewData["Title"] = "Mua gói";
}

@if (Model.Current != null)
{
    <div class="card mb-4">
        <div style="padding:18px 24px;display:flex;justify-content:space-between;align-items:center;flex-wrap:wrap;gap:10px">
            <div>
                <div style="font-size:13px;color:#6B7280">Gói hiện tại</div>
                <div style="font-size:20px;font-weight:700">@Model.CurrentPackageName</div>
                <div style="font-size:13px;color:#6B7280">
                    Còn lại <strong>@Model.RemainingQuota.ToString("N0")</strong> token · Hết hạn @Model.Current.ExpireAt.ToLocalTime().ToString("dd/MM/yyyy")
                </div>
            </div>
            <a asp-page="/Packages/Mine" class="btn-app btn-ghost"><i class="bi bi-receipt"></i> Gói của tôi</a>
        </div>
    </div>
}

<div class="row g-4">
    @foreach (var p in Model.Packages)
    {
        <div class="col-md-4">
            <div class="card h-100">
                <div style="padding:24px;display:flex;flex-direction:column;height:100%;gap:14px">
                    <div>
                        <div style="font-size:20px;font-weight:700">@p.Name</div>
                        <div style="font-size:28px;font-weight:800;color:#6366F1">
                            @p.Price.ToString("N0") <span style="font-size:14px;color:#6B7280;font-weight:600">đ</span>
                        </div>
                    </div>
                    <ul style="list-style:none;padding:0;margin:0;display:flex;flex-direction:column;gap:8px;font-size:13.5px;flex:1">
                        <li><i class="bi bi-coin text-warning me-1"></i> <strong>@p.TokenQuota.ToString("N0")</strong> token / @p.DurationDays ngày</li>
                        @foreach (var m in p.ModelList)
                        {
                            <li><i class="bi bi-cpu text-primary me-1"></i> @m</li>
                        }
                    </ul>
                    <form method="post" asp-page-handler="Buy">
                        <input type="hidden" name="packageId" value="@p.Id" />
                        <button type="submit" class="btn-app btn-primary-app w-100" style="justify-content:center">
                            <i class="bi bi-credit-card"></i> Mua qua VNPay
                        </button>
                    </form>
                </div>
            </div>
        </div>
    }
</div>
