@page "{documentId:guid}"
@model RagChatbot.RazorPages.Pages.Quiz.GenerateModel
@{
    ViewData["Title"] = "Tạo bài trắc nghiệm";
}

<div class="container mt-4">
    <div class="row justify-content-center">
        <div class="col-md-8">
            <div class="card shadow border-0 rounded-4">
                <div class="card-body p-5 text-center">
                    <h2 class="fw-bold mb-3 text-primary">Tạo bài tập tự động</h2>
                    <p class="text-muted">Tài liệu: <strong>@Model.DocumentName</strong></p>

                    @if (!ModelState.IsValid)
                    {
                        <div class="alert alert-danger text-start">
                            <div asp-validation-summary="All"></div>
                        </div>
                    }

                    <form method="post" id="generateForm" onsubmit="showLoading()">
                        <div class="mb-4">
                            <label class="form-label fw-semibold">Số lượng câu hỏi (5 - 20)</label>
                            <input type="number" asp-for="NumberOfQuestions" class="form-control form-control-lg text-center" min="5" max="20" />
                        </div>
                        
                        <button type="submit" class="btn btn-primary btn-lg px-5 rounded-pill" id="submitBtn">
                            <i class="bi bi-magic me-2"></i> Bắt đầu tạo (AI)
                        </button>
                    </form>

                    <div id="loadingSection" class="mt-4 d-none">
                        <div class="spinner-border text-primary" role="status" style="width: 3rem; height: 3rem;">
                            <span class="visually-hidden">Loading...</span>
                        </div>
                        <p class="mt-3 fw-semibold text-primary">AI đang đọc tài liệu và ra đề... Vui lòng chờ khoảng 10-20 giây.</p>
                    </div>
                </div>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    <script>
        function showLoading() {
            document.getElementById('submitBtn').disabled = true;
            document.getElementById('submitBtn').innerHTML = '<i class="bi bi-hourglass-split me-2"></i> Đang xử lý...';
            document.getElementById('loadingSection').classList.remove('d-none');
        }
    </script>
}
