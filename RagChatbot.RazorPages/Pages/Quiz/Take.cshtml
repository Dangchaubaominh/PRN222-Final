@page "{id:int}"
@model RagChatbot.RazorPages.Pages.Quiz.TakeModel
@{
    ViewData["Title"] = Model.QuizDto?.Title;
}

<div class="container mt-4 mb-5">
    @if (Model.QuizDto != null)
    {
        <div class="card shadow-sm border-0 mb-4">
            <div class="card-body bg-light rounded-top text-center py-4">
                <h3 class="mb-0 text-primary fw-bold">@Model.QuizDto.Title</h3>
                <p class="text-muted mt-2 mb-0"><i class="bi bi-clock"></i> Thời gian sinh: @Model.QuizDto.CreatedAt.ToLocalTime().ToString("dd/MM/yyyy HH:mm")</p>
            </div>
        </div>

        <form method="post">
            @{ int qIndex = 1; }
            @foreach (var q in Model.QuizDto.Questions)
            {
                <div class="card shadow-sm border-0 mb-4 rounded-4">
                    <div class="card-body p-4">
                        <h5 class="fw-semibold mb-4">
                            <span class="badge bg-primary rounded-pill me-2">Câu @qIndex</span>
                            @q.Content
                        </h5>
                        <div class="ps-3">
                            <div class="form-check mb-3">
                                <input class="form-check-input" type="radio" name="Answers[@q.Id]" id="q_@(q.Id)_A" value="A" required>
                                <label class="form-check-label fs-6" for="q_@(q.Id)_A">
                                    <strong>A.</strong> @q.OptionA
                                </label>
                            </div>
                            <div class="form-check mb-3">
                                <input class="form-check-input" type="radio" name="Answers[@q.Id]" id="q_@(q.Id)_B" value="B" required>
                                <label class="form-check-label fs-6" for="q_@(q.Id)_B">
                                    <strong>B.</strong> @q.OptionB
                                </label>
                            </div>
                            <div class="form-check mb-3">
                                <input class="form-check-input" type="radio" name="Answers[@q.Id]" id="q_@(q.Id)_C" value="C" required>
                                <label class="form-check-label fs-6" for="q_@(q.Id)_C">
                                    <strong>C.</strong> @q.OptionC
                                </label>
                            </div>
                            <div class="form-check mb-3">
                                <input class="form-check-input" type="radio" name="Answers[@q.Id]" id="q_@(q.Id)_D" value="D" required>
                                <label class="form-check-label fs-6" for="q_@(q.Id)_D">
                                    <strong>D.</strong> @q.OptionD
                                </label>
                            </div>
                        </div>
                    </div>
                </div>
                qIndex++;
            }

            <div class="text-center mt-5">
                <button type="submit" class="btn btn-success btn-lg px-5 rounded-pill shadow-sm">
                    <i class="bi bi-check-circle me-2"></i> Nộp bài
                </button>
            </div>
        </form>
    }
</div>
