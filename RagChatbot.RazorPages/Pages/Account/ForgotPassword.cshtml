@page
@model RagChatbot.RazorPages.Pages.Account.ForgotPasswordModel
@{
    ViewData["Title"] = "Quên mật khẩu";
    Layout = null;
}
<!DOCTYPE html>
<html lang="vi">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>Quên mật khẩu — EduChatbot</title>
    <link rel="stylesheet" href="~/lib/bootstrap/dist/css/bootstrap.min.css" />
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.3/font/bootstrap-icons.min.css" />
    <link rel="stylesheet" href="~/css/site.css" asp-append-version="true" />
</head>
<body>
<div class="login-page">
    <div class="login-glow login-glow-1"></div>
    <div class="login-glow login-glow-2"></div>

    <div class="login-box fade-in-up">
        <div class="login-logo">🔑</div>
        <h1 class="login-title">Quên mật khẩu</h1>
        <p class="login-sub">Nhập Gmail đã liên kết với tài khoản của bạn</p>

        @if (Model.Sent)
        {
            <!-- Trạng thái đã gửi -->
            <div style="text-align:center;padding:8px 0 20px">
                <div style="font-size:48px;margin-bottom:16px">📬</div>
                <div style="background:rgba(16,185,129,.15);border:1px solid rgba(16,185,129,.3);border-radius:12px;padding:16px 20px;margin-bottom:20px">
                    <p style="margin:0;font-size:14px;color:#6ee7b7;line-height:1.7">
                        Nếu Gmail của bạn tồn tại trong hệ thống, một email chứa link đặt lại mật khẩu đã được gửi.<br>
                        <strong>Link có hiệu lực trong 30 phút.</strong>
                    </p>
                </div>
                <p style="font-size:12px;color:rgba(255,255,255,.4);margin-bottom:20px">
                    Không thấy email? Kiểm tra thư mục <strong>Spam / Junk</strong>.
                </p>
            </div>

            <a asp-page="/Account/Login" class="login-btn" style="text-decoration:none;display:block;text-align:center">
                <i class="bi bi-arrow-left"></i> &nbsp;Quay lại đăng nhập
            </a>
        }
        else
        {
            <!-- Form nhập email -->
            <form method="post">
                <div style="margin-bottom:24px">
                    <label class="login-label"><i class="bi bi-envelope me-1"></i> Gmail của bạn</label>
                    <input type="email" asp-for="Email" class="login-input"
                           placeholder="VD: nguyenvana@gmail.com"
                           required autocomplete="email" />
                </div>
                <button type="submit" class="login-btn">
                    Gửi link đặt lại &nbsp;<i class="bi bi-send"></i>
                </button>
            </form>

            <div style="text-align:center;margin-top:20px">
                <a asp-page="/Account/Login" style="font-size:13px;color:rgba(255,255,255,.45);text-decoration:none">
                    <i class="bi bi-arrow-left"></i> Quay lại đăng nhập
                </a>
            </div>
        }

        <p style="text-align:center;font-size:11px;color:rgba(255,255,255,.2);margin-top:28px;margin-bottom:0">
            © 2026 EduChatbot · AI-Powered Learning Platform
        </p>
    </div>
</div>
</body>
</html>
