@page
@model RagChatbot.RazorPages.Pages.Account.AccessDeniedModel
@{
    ViewData["Title"] = "Không có quyền truy cập";
    Layout = null;
}
<!DOCTYPE html>
<html lang="vi">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>Không có quyền truy cập — EduChatbot</title>
    <link rel="stylesheet" href="~/lib/bootstrap/dist/css/bootstrap.min.css" />
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.3/font/bootstrap-icons.min.css" />
    <link rel="stylesheet" href="~/css/site.css" asp-append-version="true" />
</head>
<body>
<div class="login-page">
    <div class="login-glow login-glow-1"></div>
    <div class="login-glow login-glow-2"></div>

    <div class="login-box fade-in-up" style="text-align:center">
        <div class="login-logo">🚫</div>
        <h1 class="login-title">Không có quyền truy cập</h1>
        <p class="login-sub">Bạn không có quyền truy cập vào trang này.</p>

        <a asp-page="/Home/Index" class="login-btn" style="text-decoration:none;display:block;text-align:center;margin-top:20px">
            <i class="bi bi-house-door"></i> &nbsp;Về trang chủ
        </a>
        <div style="text-align:center;margin-top:16px">
            <a href="@Url.Page("/Account/Logout")" style="font-size:13px;color:rgba(255,255,255,.45);text-decoration:none">
                <i class="bi bi-box-arrow-right me-1"></i>Đăng xuất
            </a>
        </div>
    </div>
</div>
</body>
</html>
