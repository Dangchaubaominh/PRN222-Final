@page
@model RagChatbot.RazorPages.Pages.Account.ResetPasswordModel
@{
    ViewData["Title"] = "Đặt lại mật khẩu";
    Layout = null;
    bool expired = Model.Expired;
}
<!DOCTYPE html>
<html lang="vi">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>Đặt lại mật khẩu — EduChatbot</title>
    <link rel="stylesheet" href="~/lib/bootstrap/dist/css/bootstrap.min.css" />
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.3/font/bootstrap-icons.min.css" />
    <link rel="stylesheet" href="~/css/site.css" asp-append-version="true" />
</head>
<body>
<div class="login-page">
    <div class="login-glow login-glow-1"></div>
    <div class="login-glow login-glow-2"></div>

    <div class="login-box fade-in-up">

        @if (expired)
        {
            <!-- Link hết hạn hoặc không hợp lệ -->
            <div style="text-align:center;padding:8px 0 20px">
                <div style="font-size:48px;margin-bottom:16px">⏰</div>
                <h1 class="login-title" style="font-size:22px">Link đã hết hạn</h1>
                <p class="login-sub">Link đặt lại mật khẩu không còn hiệu lực.<br>Mỗi link chỉ dùng được trong <strong>30 phút</strong>.</p>

                <div style="background:rgba(239,68,68,.12);border:1px solid rgba(239,68,68,.3);border-radius:12px;padding:14px 18px;margin:20px 0">
                    <p style="margin:0;font-size:13px;color:#fca5a5;line-height:1.6">
                        Vui lòng quay lại trang quên mật khẩu và yêu cầu link mới.
                    </p>
                </div>

                <a asp-page="/Account/ForgotPassword" class="login-btn" style="text-decoration:none;display:block;text-align:center;margin-bottom:12px">
                    <i class="bi bi-arrow-repeat"></i> &nbsp;Yêu cầu link mới
                </a>
                <a asp-page="/Account/Login" style="font-size:13px;color:rgba(255,255,255,.4);text-decoration:none">
                    <i class="bi bi-arrow-left"></i> Quay lại đăng nhập
                </a>
            </div>
        }
        else
        {
            <!-- Form đặt mật khẩu mới -->
            <div class="login-logo">🔐</div>
            <h1 class="login-title">Mật khẩu mới</h1>
            <p class="login-sub">Nhập mật khẩu mới cho tài khoản của bạn</p>

            @if (Model.Error != null)
            {
                <div class="login-error">
                    <i class="bi bi-exclamation-triangle-fill me-1"></i> @Model.Error
                </div>
            }

            <form method="post">
                <input type="hidden" asp-for="Token" />

                <div style="margin-bottom:16px">
                    <label class="login-label"><i class="bi bi-lock me-1"></i> Mật khẩu mới</label>
                    <input type="password" asp-for="NewPassword" class="login-input"
                           placeholder="Tối thiểu 4 ký tự"
                           required minlength="4" autocomplete="new-password" />
                </div>

                <div style="margin-bottom:24px">
                    <label class="login-label"><i class="bi bi-lock-fill me-1"></i> Xác nhận mật khẩu</label>
                    <input type="password" asp-for="ConfirmPassword" class="login-input"
                           placeholder="Nhập lại mật khẩu mới"
                           required minlength="4" autocomplete="new-password" />
                </div>

                <!-- Countdown timer -->
                <div style="background:rgba(245,158,11,.1);border:1px solid rgba(245,158,11,.25);border-radius:10px;padding:10px 14px;margin-bottom:20px;display:flex;align-items:center;gap:8px">
                    <i class="bi bi-clock" style="color:#fbbf24;font-size:14px"></i>
                    <span style="font-size:12px;color:#fbbf24" id="timerText">Trang này có hiệu lực trong 30:00</span>
                </div>

                <button type="submit" class="login-btn">
                    Đặt lại mật khẩu &nbsp;<i class="bi bi-check-circle"></i>
                </button>
            </form>

            <div style="text-align:center;margin-top:16px">
                <a asp-page="/Account/Login" style="font-size:13px;color:rgba(255,255,255,.4);text-decoration:none">
                    <i class="bi bi-arrow-left"></i> Quay lại đăng nhập
                </a>
            </div>
        }

        <p style="text-align:center;font-size:11px;color:rgba(255,255,255,.2);margin-top:28px;margin-bottom:0">
            © 2026 EduChatbot · AI-Powered Learning Platform
        </p>
    </div>
</div>

@if (!expired)
{
    <script>
    // Đếm ngược 30 phút — chỉ hiển thị, server vẫn là nơi kiểm tra thực sự
    var seconds = 30 * 60;
    var timerEl = document.getElementById('timerText');
    var interval = setInterval(function() {
        seconds--;
        if (seconds <= 0) {
            clearInterval(interval);
            timerEl.textContent = 'Link đã hết hạn — hãy yêu cầu link mới.';
            timerEl.style.color = '#f87171';
            document.querySelector('button[type="submit"]').disabled = true;
            return;
        }
        var m = Math.floor(seconds / 60);
        var s = seconds % 60;
        timerEl.textContent = 'Trang này có hiệu lực trong ' + m + ':' + (s < 10 ? '0' : '') + s;
    }, 1000);
    </script>
}
</body>
</html>
